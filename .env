# =============================================================================
# KAFKA CDC LAB — Environment Configuration
# =============================================================================
# Chỉnh sửa file này để điều chỉnh các tham số triển khai.
# Sau khi thay đổi, chạy: docker compose down && docker compose up -d

# -----------------------------------------------------------------------------
# KAFKA (KRaft Mode — không cần ZooKeeper)
# -----------------------------------------------------------------------------
KAFKA_NODE_ID=1
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk      # Không đổi giá trị này sau khi khởi tạo
KAFKA_BROKER_PORT=9092                          # Port expose ra host
KAFKA_CONTROLLER_PORT=9093
KAFKA_LOG_RETENTION_HOURS=168                   # Giữ message 7 ngày
KAFKA_LOG_SEGMENT_BYTES=1073741824              # 1 GB per segment
KAFKA_AUTO_CREATE_TOPICS=true

# -----------------------------------------------------------------------------
# KAFKA UI
# -----------------------------------------------------------------------------
KAFKA_UI_PORT=8080                              # Truy cập: http://localhost:8080

# -----------------------------------------------------------------------------
# POSTGRESQL (Debezium image — WAL/logical replication đã bật sẵn)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5434                         # Port expose ra host (tránh xung đột nếu đã có Postgres)
POSTGRES_DB=labdb
POSTGRES_USER=labuser
POSTGRES_PASSWORD=labpassword
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=replicatorpassword

# -----------------------------------------------------------------------------
# KAFKA CONNECT (Distributed mode + Debezium connectors)
# -----------------------------------------------------------------------------
CONNECT_PORT=8083                               # REST API: http://localhost:8083
CONNECT_GROUP_ID=kafka-connect-lab-cluster
CONNECT_CONFIG_TOPIC=connect-configs
CONNECT_OFFSET_TOPIC=connect-offsets
CONNECT_STATUS_TOPIC=connect-status
CONNECT_CONFIG_REPLICATION_FACTOR=1            # Lab: 1 broker nên để 1
CONNECT_OFFSET_REPLICATION_FACTOR=1
CONNECT_STATUS_REPLICATION_FACTOR=1
CONNECT_KEY_CONVERTER=org.apache.kafka.connect.json.JsonConverter
CONNECT_VALUE_CONVERTER=org.apache.kafka.connect.json.JsonConverter

# -----------------------------------------------------------------------------
# RESOURCE LIMITS (Tuỳ chỉnh theo máy của bạn)
# -----------------------------------------------------------------------------
KAFKA_HEAP_OPTS=-Xms512m -Xmx1g
CONNECT_HEAP_OPTS=-Xms256m -Xmx512m
